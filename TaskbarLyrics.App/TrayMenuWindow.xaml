<Window x:Class="TaskbarLyrics.App.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="180"
        Height="110"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="TrayMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#303030" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#3A3A3A" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Top" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chrome" Property="CornerRadius" Value="8,8,0,0" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Top" />
                                    <Condition Property="IsPressed" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chrome" Property="CornerRadius" Value="8,8,0,0" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Bottom" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chrome" Property="CornerRadius" Value="0,0,8,8" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Bottom" />
                                    <Condition Property="IsPressed" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chrome" Property="CornerRadius" Value="0,0,8,8" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="6"
            CornerRadius="8"
            Background="#1E1E1E"
            BorderBrush="Transparent"
            BorderThickness="0"
            Padding="0"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="5"
                              Opacity="0.38"
                              Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="32" />
                <RowDefinition Height="1" />
                <RowDefinition Height="32" />
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                    Style="{StaticResource TrayMenuButtonStyle}"
                    Tag="Top"
                    Click="ToggleLyricsButton_Click">
                <TextBlock Text="显示/隐藏歌词"
                           VerticalAlignment="Center"
                           Foreground="#FFFFFF"
                           FontFamily="Microsoft YaHei UI"
                           FontSize="12.5" />
            </Button>

            <Button Grid.Row="1"
                    Style="{StaticResource TrayMenuButtonStyle}"
                    Click="SettingsButton_Click">
                <TextBlock Text="设置"
                           VerticalAlignment="Center"
                           Foreground="#FFFFFF"
                           FontFamily="Microsoft YaHei UI"
                           FontSize="12.5" />
            </Button>

            <Border Grid.Row="2"
                    Height="1"
                    VerticalAlignment="Center"
                    Background="#4A4A4A" />

            <Button Grid.Row="3"
                    Style="{StaticResource TrayMenuButtonStyle}"
                    Tag="Bottom"
                    Click="ExitButton_Click">
                <TextBlock Text="退出"
                           VerticalAlignment="Center"
                           Foreground="#FFFFFF"
                           FontFamily="Microsoft YaHei UI"
                           FontSize="12.5" />
            </Button>
        </Grid>
    </Border>
</Window>
