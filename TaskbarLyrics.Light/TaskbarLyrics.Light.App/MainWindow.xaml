<Window x:Class="TaskbarLyrics.Light.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TaskbarLyrics.Light.App"
        Title="TaskbarLyrics Light"
        Width="560"
        Height="40"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="Transparent">
    <local:LyricsDisplayControl x:Name="LyricsDisplay"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Margin="8,3" />
</Window>
