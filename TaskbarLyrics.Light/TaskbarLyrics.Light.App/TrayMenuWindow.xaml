<Window x:Class="TaskbarLyrics.Light.App.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="190"
        Height="120"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="TrayMenuBackgroundBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="TrayMenuHoverBrush" Color="#303030" />
        <SolidColorBrush x:Key="TrayMenuPressedBrush" Color="#3A3A3A" />
        <SolidColorBrush x:Key="TrayMenuTextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TrayMenuSeparatorBrush" Color="#4A4A4A" />

        <Style x:Key="TrayMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TrayMenuHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource TrayMenuPressedBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Top" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chrome" Property="CornerRadius" Value="8,8,0,0" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Top" />
                                    <Condition Property="IsPressed" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chrome" Property="CornerRadius" Value="8,8,0,0" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Bottom" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chrome" Property="CornerRadius" Value="0,0,8,8" />
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Bottom" />
                                    <Condition Property="IsPressed" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chrome" Property="CornerRadius" Value="0,0,8,8" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Border CornerRadius="8"
                Background="{DynamicResource TrayMenuBackgroundBrush}"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32" />
                    <RowDefinition Height="32" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="32" />
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        Style="{StaticResource TrayMenuButtonStyle}"
                        Tag="Top"
                        Click="ToggleLyricsButton_Click">
                    <TextBlock Text="显示/隐藏歌词"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TrayMenuTextBrush}"
                               FontFamily="Microsoft YaHei UI"
                               FontSize="12.5" />
                </Button>

                <Button Grid.Row="1"
                        Style="{StaticResource TrayMenuButtonStyle}"
                        Click="SettingsButton_Click">
                    <TextBlock Text="设置"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TrayMenuTextBrush}"
                               FontFamily="Microsoft YaHei UI"
                               FontSize="12.5" />
                </Button>

                <Border Grid.Row="2"
                        Height="1"
                        VerticalAlignment="Center"
                        Background="{DynamicResource TrayMenuSeparatorBrush}" />

                <Button Grid.Row="3"
                        Style="{StaticResource TrayMenuButtonStyle}"
                        Tag="Bottom"
                        Click="ExitButton_Click">
                    <TextBlock Text="退出"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TrayMenuTextBrush}"
                               FontFamily="Microsoft YaHei UI"
                               FontSize="12.5" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
