<Window x:Class="TaskbarLyrics.Light.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:TaskbarLyrics.Light.App.Ui"
        Title="TaskbarLyrics Light - 设置"
        Width="1280"
        Height="860"
        MinWidth="1080"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#070E1D"
        Foreground="#F8FAFC"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Ui/SettingsTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="#070E1D">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="248" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 侧边栏 -->
        <Border Grid.Column="0"
                Background="#F20D182B"
                BorderBrush="#2E78A0FF"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="24,24,14,20">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="28" Height="28"
                                BorderBrush="#4D7AFF"
                                BorderThickness="2"
                                Margin="0,0,12,0">
                            <TextBlock Text="◎"
                                       Foreground="#55A2FF"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock x:Name="BrandTitle"
                                   Text="TaskbarLyrics"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <Button x:Name="SidebarToggleButton"
                        DockPanel.Dock="Bottom"
                        Content="‹"
                        Width="36"
                        Height="36"
                        Margin="23,0,0,18"
                        HorizontalAlignment="Left"
                        Background="#8A0B1528"
                        Foreground="#8FB0FF"
                        BorderBrush="#2478A0FF"
                        BorderThickness="1"
                        FontSize="22"
                        Cursor="Hand" />

                <StackPanel Margin="14,0,14,0">
                    <RadioButton x:Name="NavPlayers" Style="{StaticResource SettingsNavButtonStyle}" GroupName="Nav" IsChecked="True" Checked="Nav_Checked">
                        <StackPanel Orientation="Horizontal"><TextBlock Width="28" Text="▷" /><TextBlock Text="播放器" FontWeight="SemiBold" /></StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavLyrics" Style="{StaticResource SettingsNavButtonStyle}" GroupName="Nav" Checked="Nav_Checked">
                        <StackPanel Orientation="Horizontal"><TextBlock Width="28" Text="Aa" /><TextBlock Text="歌词" FontWeight="SemiBold" /></StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavAppearance" Style="{StaticResource SettingsNavButtonStyle}" GroupName="Nav" Checked="Nav_Checked">
                        <StackPanel Orientation="Horizontal"><TextBlock Width="28" Text="◌" /><TextBlock Text="外观" FontWeight="SemiBold" /></StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavLayout" Style="{StaticResource SettingsNavButtonStyle}" GroupName="Nav" Checked="Nav_Checked">
                        <StackPanel Orientation="Horizontal"><TextBlock Width="28" Text="▦" /><TextBlock Text="布局" FontWeight="SemiBold" /></StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavDebug" Style="{StaticResource SettingsNavButtonStyle}" GroupName="Nav" Checked="Nav_Checked">
                        <StackPanel Orientation="Horizontal"><TextBlock Width="28" Text="♢" /><TextBlock Text="调试" FontWeight="SemiBold" /></StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavAbout" Style="{StaticResource SettingsNavButtonStyle}" GroupName="Nav" Checked="Nav_Checked">
                        <StackPanel Orientation="Horizontal"><TextBlock Width="28" Text="i" /><TextBlock Text="关于" FontWeight="SemiBold" /></StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 主区域 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="98" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="40,18,36,0">
                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="设置" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="调整播放器识别、歌词显示、外观和任务栏布局。"
                               Foreground="{StaticResource SettingsMutedBrush}"
                               FontSize="12"
                               Margin="0,7,0,0" />
                </StackPanel>
                <Button x:Name="ResetDefaultsButton"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Style="{StaticResource SettingsPrimaryButtonStyle}"
                        Content="↺  恢复默认设置" />
            </Grid>

            <ScrollViewer x:Name="ContentScroll"
                          Grid.Row="1"
                          Margin="40,0,36,36"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly"
                          CanContentScroll="False"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel>
                    <!-- 播放器 -->
                    <Border x:Name="SectionPlayers" Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="播放器集成" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="选择要监听的音乐播放器，并通过拖拽调整优先识别顺序。"
                                       Foreground="{StaticResource SettingsMutedBrush}"
                                       FontSize="12"
                                       Margin="0,5,0,14" />
                            <UniformGrid Columns="2" Margin="0,0,0,10">
                                <Border Style="{StaticResource SettingsRowCardStyle}" Margin="0,0,6,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image x:Name="QQIcon" Width="32" Height="32" Margin="0,0,13,0" />
                                        <TextBlock Grid.Column="1" Text="QQ音乐" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <CheckBox x:Name="EnableQQMusicCheck" Grid.Column="2" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingsRowCardStyle}" Margin="6,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image x:Name="NeteaseIcon" Width="32" Height="32" Margin="0,0,13,0" />
                                        <TextBlock Grid.Column="1" Text="网易云音乐" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <CheckBox x:Name="EnableNeteaseCheck" Grid.Column="2" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingsRowCardStyle}" Margin="0,0,6,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image x:Name="KugouIcon" Width="32" Height="32" Margin="0,0,13,0" />
                                        <TextBlock Grid.Column="1" Text="酷狗音乐" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <CheckBox x:Name="EnableKugouCheck" Grid.Column="2" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingsRowCardStyle}" Margin="6,0,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image x:Name="SpotifyIcon" Width="32" Height="32" Margin="0,0,13,0" />
                                        <TextBlock Grid.Column="1" Text="Spotify" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <CheckBox x:Name="EnableSpotifyCheck" Grid.Column="2" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                    </Grid>
                                </Border>
                            </UniformGrid>
                            <ui:SourceOrderList x:Name="SourceOrderList" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- 歌词 -->
                    <Border x:Name="SectionLyrics" Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="歌词设置" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="控制歌词窗口启动行为与显示辅助项。"
                                       Foreground="{StaticResource SettingsMutedBrush}"
                                       FontSize="12"
                                       Margin="0,5,0,14" />
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="启动时显示歌词" FontWeight="SemiBold" />
                                        <TextBlock Text="应用启动后自动显示歌词悬浮窗口。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="ShowLyricsOnStartupCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="开机自启动" FontWeight="SemiBold" />
                                        <TextBlock Text="登录 Windows 后自动在后台运行（托盘图标）。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="StartWithWindowsCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="播放器打开时显示歌词" FontWeight="SemiBold" />
                                        <TextBlock Text="检测到已启用的音乐播放器并开始播放时，自动显示歌词窗口。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="AutoShowLyricsWhenPlayerOpensCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="播放器关闭时隐藏歌词" FontWeight="SemiBold" />
                                        <TextBlock Text="所有已启用播放器均停止或无播放会话时，自动隐藏歌词窗口。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="AutoHideLyricsWhenPlayerClosesCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="纯音乐时显示频谱" FontWeight="SemiBold" />
                                        <TextBlock Text="歌曲识别为纯音乐时，在歌词区域显示实时频谱。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="EnablePureMusicSpectrumCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="启用频谱" FontWeight="SemiBold" />
                                        <TextBlock Text="总开关。关闭后纯音乐与无歌词时都不会显示频谱。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="EnableSpectrumCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="未检索到歌词时显示频谱" FontWeight="SemiBold" />
                                        <TextBlock Text="歌词源没有返回可用歌词时，用频谱替代“暂未找到歌词”。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="ShowSpectrumWhenLyricsNotFoundCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="优先使用本地歌词" FontWeight="SemiBold" />
                                        <TextBlock Text="播放本地音乐时，先从下方目录中匹配同名歌词文件。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="EnableLocalLyricsCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="本地音乐目录" FontWeight="SemiBold" />
                                    <TextBlock Text="一行一个目录，支持同名 .lrc / .qrc / .krc 歌词文件。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,10" />
                                    <TextBox x:Name="LocalMusicFoldersBox"
                                             AcceptsReturn="True"
                                             MinHeight="72"
                                             VerticalScrollBarVisibility="Auto"
                                             TextWrapping="Wrap"
                                             FontFamily="Consolas, Courier New"
                                             Padding="10,8" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="显示背景" FontWeight="SemiBold" />
                                        <TextBlock Text="为歌词窗口启用半透明背景。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="ShowBackgroundCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="显示边框" FontWeight="SemiBold" />
                                        <TextBlock Text="为歌词窗口绘制边框，便于深浅背景上分辨。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="ShowBorderCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 外观 -->
                    <Border x:Name="SectionAppearance" Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="外观" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="调整歌词字体、字号、行间距和文字颜色。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,5,0,14" />
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="字号" FontWeight="SemiBold" />
                                    <ui:NumberStepper x:Name="FontSizeStepper" Grid.Column="1" Minimum="10" Maximum="40" Step="1" Decimals="0" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="根据字号自动调整行间距" FontWeight="SemiBold" />
                                        <TextBlock Text="开启后两行歌词间距随字号变化，可叠加下方间距偏移。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="AutoAdjustLineGapCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="LineGapLabel" Text="歌词行间距 (px)" FontWeight="SemiBold" />
                                        <TextBlock x:Name="LineGapHint" Text="关闭自动调整时生效。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <ui:NumberStepper x:Name="LineGapStepper" Grid.Column="1" Minimum="0" Maximum="24" Step="1" Decimals="0" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="LineGapOffsetLabel" Text="自动行间距偏移 (px)" FontWeight="SemiBold" />
                                        <TextBlock x:Name="LineGapOffsetHint" Text="在自动计算间距上额外增减，可为正或负。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <ui:NumberStepper x:Name="LineGapOffsetStepper" Grid.Column="1" Minimum="-12" Maximum="24" Step="1" Decimals="0" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="字体" FontWeight="SemiBold" />
                                    <ComboBox x:Name="FontFamilyCombo"
                                              Grid.Column="1"
                                              Style="{StaticResource SettingsComboBoxStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="字重" FontWeight="SemiBold" />
                                    <ComboBox x:Name="FontWeightCombo" Grid.Column="1" Style="{StaticResource SettingsComboBoxStyle}">
                                        <ComboBoxItem Content="细体" Tag="Light" />
                                        <ComboBoxItem Content="常规" Tag="Normal" />
                                        <ComboBoxItem Content="中等" Tag="Medium" />
                                        <ComboBoxItem Content="半粗体" Tag="SemiBold" />
                                        <ComboBoxItem Content="粗体" Tag="Bold" />
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="文字颜色" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="136" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="ForegroundModeCombo" Style="{StaticResource SettingsComboBoxStyle}">
                                            <ComboBoxItem Content="深色" Tag="Dark" />
                                            <ComboBoxItem Content="浅色" Tag="Light" />
                                            <ComboBoxItem Content="自定义" Tag="Custom" />
                                        </ComboBox>
                                        <Button x:Name="ColorPickerButton"
                                                Grid.Column="2"
                                                Height="38"
                                                Cursor="Hand"
                                                Foreground="{StaticResource SettingsTextBrush}"
                                                Click="ColorPickerButton_Click"
                                                Background="{StaticResource SettingsInputBrush}"
                                                BorderBrush="#2978A0FF"
                                                BorderThickness="1"
                                                Padding="10,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="ColorSwatch"
                                                        Width="22"
                                                        Height="22"
                                                        CornerRadius="7"
                                                        BorderBrush="#85FFFFFF"
                                                        BorderThickness="1"
                                                        Background="White"
                                                        Margin="0,0,10,0" />
                                                <TextBlock x:Name="ColorValueText"
                                                           Grid.Column="1"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2" Text="✎" Foreground="#A3FFFFFF" VerticalAlignment="Center" />
                                            </Grid>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="文字阴影" FontWeight="SemiBold" />
                                        <TextBlock Text="为歌词文字增加轻量阴影，提高复杂背景上的可读性。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="ShowTextShadowCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 布局 -->
                    <Border x:Name="SectionLayout" Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="窗口设置" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="调整任务栏歌词窗口的位置、尺寸与透明度。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,5,0,14" />
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="背景不透明度" FontWeight="SemiBold" />
                                        <TextBlock Text="范围 0 到 1，数值越大背景越不透明。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <ui:NumberStepper x:Name="BackgroundOpacityStepper" Grid.Column="1" Minimum="0" Maximum="1" Step="0.05" Decimals="2" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="根据歌词自动调整窗口宽度" FontWeight="SemiBold" />
                                        <TextBlock Text="开启后窗口宽度随当前歌词文本长度变化，可叠加下方宽度偏移。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="AutoAdjustWindowWidthCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="WindowWidthLabel" Text="窗口宽度 (px)" FontWeight="SemiBold" />
                                        <TextBlock x:Name="WindowWidthHint" Text="关闭自动调整时生效。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <ui:NumberStepper x:Name="WindowWidthStepper" Grid.Column="1" Minimum="320" Maximum="1400" Step="10" Decimals="0" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="WindowWidthOffsetLabel" Text="自动宽度偏移 (px)" FontWeight="SemiBold" />
                                        <TextBlock x:Name="WindowWidthOffsetHint" Text="在自动计算宽度上额外增减，可为正或负。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <ui:NumberStepper x:Name="WindowWidthOffsetStepper" Grid.Column="1" Minimum="-200" Maximum="400" Step="10" Decimals="0" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="根据字号自动调整窗口高度" FontWeight="SemiBold" />
                                        <TextBlock Text="开启后窗口高度随歌词字号变化，可叠加下方高度偏移。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="AutoAdjustWindowHeightCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="WindowHeightLabel" Text="窗口高度 (px)" FontWeight="SemiBold" />
                                        <TextBlock x:Name="WindowHeightHint" Text="关闭自动调整时生效。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <ui:NumberStepper x:Name="WindowHeightStepper" Grid.Column="1" Minimum="36" Maximum="240" Step="2" Decimals="0" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="WindowHeightOffsetLabel" Text="自动高度偏移 (px)" FontWeight="SemiBold" />
                                        <TextBlock x:Name="WindowHeightOffsetHint" Text="在自动计算高度上额外增减，可为正或负。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <ui:NumberStepper x:Name="WindowHeightOffsetStepper" Grid.Column="1" Minimum="-40" Maximum="80" Step="2" Decimals="0" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="强制置顶歌词窗口" FontWeight="SemiBold" />
                                        <TextBlock Text="关闭后歌词窗口不再始终位于最前，便于操作其他窗口。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="ForceAlwaysOnTopCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="水平锚点" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <ComboBox x:Name="HorizontalAnchorCombo" Grid.Column="1" Style="{StaticResource SettingsComboBoxStyle}">
                                        <ComboBoxItem Content="左侧" Tag="Left" />
                                        <ComboBoxItem Content="居中" Tag="Center" />
                                        <ComboBoxItem Content="右侧" Tag="Right" />
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="X 偏移 (px)" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <ui:NumberStepper x:Name="XOffsetStepper" Grid.Column="1" Minimum="-2000" Maximum="2000" Step="10" Decimals="0" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="280" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Y 偏移 (px)" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <ui:NumberStepper x:Name="YOffsetStepper" Grid.Column="1" Minimum="-2000" Maximum="2000" Step="10" Decimals="0" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 调试 -->
                    <Border x:Name="SectionDebug" Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="数据与调试" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="清理缓存或打开辅助调试选项。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,5,0,14" />
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="SMTC 时间轴监视器" FontWeight="SemiBold" />
                                        <TextBlock Text="用于观察播放器时间轴数据，排查同步问题。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="EnableSmtcTimelineMonitorCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="频谱调试" FontWeight="SemiBold" />
                                        <TextBlock Text="打开临时滑块面板，实时调整频谱响应参数。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <Button x:Name="SpectrumTuningButton" Grid.Column="1" Content="打开调试" Style="{StaticResource SettingsPrimaryButtonStyle}" Height="38" MinWidth="96" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="歌词缓存" FontWeight="SemiBold" />
                                        <TextBlock Text="清除后首次重新匹配会稍慢。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <Button x:Name="ClearCacheButton" Grid.Column="1" Content="清除缓存" Style="{StaticResource SettingsDangerButtonStyle}" Height="38" MinWidth="96" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 关于 -->
                    <Border x:Name="SectionAbout" Style="{StaticResource SettingsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="关于" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="版本信息与更新检查。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,5,0,14" />
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="TaskbarLyrics Light" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock x:Name="AppVersionText"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource SettingsMutedBrush}"
                                               FontSize="12" />
                                    <TextBlock Text="原生 WPF 轻量版，共享 TaskbarLyrics.Core 歌词检索逻辑。"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource SettingsMutedBrush}"
                                               FontSize="12"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="自动检查更新" FontWeight="SemiBold" />
                                        <TextBlock Text="每天最多检查一次，发现新版本时通过系统通知提醒。" Foreground="{StaticResource SettingsMutedBrush}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <CheckBox x:Name="AutoCheckUpdatesCheck" Grid.Column="1" Style="{StaticResource SettingsToggleSwitchStyle}" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRowCardStyle}">
                                <StackPanel>
                                    <Button x:Name="CheckUpdateButton"
                                            Content="检查更新"
                                            Style="{StaticResource SettingsPrimaryButtonStyle}"
                                            Height="38"
                                            MinWidth="120"
                                            HorizontalAlignment="Left"
                                            Click="CheckUpdateButton_Click" />
                                    <TextBlock x:Name="UpdateStatusText"
                                               Margin="0,10,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource SettingsMutedBrush}"
                                               FontSize="12" />
                                    <Button x:Name="OpenRepositoryButton"
                                            Margin="0,12,0,0"
                                            Content="打开 GitHub 仓库"
                                            Style="{StaticResource SettingsPrimaryButtonStyle}"
                                            Height="38"
                                            MinWidth="160"
                                            HorizontalAlignment="Left"
                                            Click="OpenRepositoryButton_Click" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
