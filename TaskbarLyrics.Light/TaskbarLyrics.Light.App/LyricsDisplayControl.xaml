<UserControl x:Class="TaskbarLyrics.Light.App.LyricsDisplayControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             Background="Transparent">
    <Border x:Name="SurfaceBorder"
            CornerRadius="8"
            Background="Transparent"
            BorderThickness="0"
            Padding="4,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="34" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="CoverBorder"
                    Grid.Column="0"
                    Width="34"
                    Height="34"
                    CornerRadius="6"
                    Background="#1F2937"
                    ClipToBounds="True"
                    BorderBrush="#14FFFFFF"
                    BorderThickness="1">
                <Grid>
                    <TextBlock x:Name="CoverFallbackText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#F5FFFFFF"
                               Text="N" />
                    <Image x:Name="CoverImageA" Stretch="UniformToFill" Opacity="0" />
                    <Image x:Name="CoverImageB" Stretch="UniformToFill" Opacity="0" />
                </Grid>
            </Border>

            <Grid Grid.Column="2" ClipToBounds="False" Margin="2,3,4,0">
                <Border x:Name="LyricsViewport"
                        ClipToBounds="True"
                        Margin="0,0,0,-2"
                        VerticalAlignment="Stretch">
                    <Grid x:Name="LyricsLayer" ClipToBounds="True">
                        <StackPanel x:Name="TrackPanel"
                                    RenderTransformOrigin="0,0">
                            <StackPanel.RenderTransform>
                                <TranslateTransform x:Name="TrackTransform" />
                            </StackPanel.RenderTransform>

                            <TextBlock x:Name="CurrentLineText"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Text="TaskbarLyrics 已启动"
                                       RenderTransformOrigin="0,0.5">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform Y="1" />
                                </TextBlock.RenderTransform>
                            </TextBlock>

                            <TextBlock x:Name="NextLineText"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Opacity="0.72"
                                       Text="等待歌词..."
                                       RenderTransformOrigin="0,0.5">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform Y="2" />
                                </TextBlock.RenderTransform>
                            </TextBlock>

                            <TextBlock x:Name="IncomingLineText"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Opacity="0"
                                       Text=" "
                                       RenderTransformOrigin="0,0.5">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform Y="2" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid x:Name="SpectrumLayer"
                      Opacity="0"
                      IsHitTestVisible="False"
                      VerticalAlignment="Center">
                    <StackPanel x:Name="SpectrumPanel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Height="22" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
